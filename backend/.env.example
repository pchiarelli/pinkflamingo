# Copie para .env e ajuste em produção.
PORT=3333

# Caminho do banco SQLite — em produção aponte para um DISCO PERSISTENTE
# (volume), senão o catálogo/pedidos se perdem a cada deploy.
DB_PATH=/var/data/pinkflamingo/data.sqlite

# Segredo do JWT — TROQUE por um valor longo e aleatório em produção.
JWT_SECRET=troque-por-um-segredo-bem-grande-e-aleatorio

# Senha inicial do admin (usada só no `npm run seed` na primeira vez).
ADMIN_PASSWORD=pinkflamingo

# Pix (também configurável pelo painel /admin; estes são fallback).
PIX_KEY=
PIX_NAME=Pink Flamingo
PIX_CITY=Sao Paulo
